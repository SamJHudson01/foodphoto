NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Use the pooled Neon URL for application traffic.
DATABASE_URL="postgresql://user:pass@ep-example-pooler.region.aws.neon.tech/dbname?sslmode=require&connection_limit=1&connect_timeout=15&pool_timeout=15"
# Use the direct Neon URL for Prisma migrations.
DIRECT_URL="postgresql://user:pass@ep-example.region.aws.neon.tech/dbname?sslmode=require"

CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_ACCESS_KEY_ID=
